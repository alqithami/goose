{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chmarl.com/schemas/chmarl_goose_episode.schema.json",
  "title": "CHMARL-Goose Episode Trace",
  "type": "object",
  "required": ["episode_id", "steps", "metrics"],
  "properties": {
    "episode_id": {
      "type": "string"
    },
    "config": {
      "type": "object",
      "description": "Experiment configuration and governance settings."
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "proposals", "accepted_actions", "emission_governor", "fairness_after"],
        "properties": {
          "step": {"type": "integer", "minimum": 0},
          "proposals": {"type": "array", "items": {"type": "object"}},
          "accepted_actions": {"type": "array", "items": {"type": "object"}},
          "emission_governor": {"type": "object"},
          "fairness_before": {"type": "object"},
          "fairness_after": {"type": "object"},
          "ports": {"type": "object"},
          "vessels": {"type": "object"}
        },
        "additionalProperties": true
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "total_fuel": {"type": "number"},
        "mean_fuel": {"type": "number"},
        "gini": {"type": "number"},
        "max_min_ratio": {"type": "number"},
        "emission_pressure": {"type": "number"},
        "fairness_pressure": {"type": "number"}
      },
      "additionalProperties": true
    },
    "caveats": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "additionalProperties": true
}
